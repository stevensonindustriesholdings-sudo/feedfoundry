# =============================================================================
# apps/web — local development (copy to .env.local, never commit secrets)
# =============================================================================
# Live API (day two):
#   FEEDFOUNDRY_API_BASE_URL=https://api-v2-iqho-production.up.railway.app
#   NEXT_PUBLIC_FEEDFOUNDRY_API_BASE_URL=https://api-v2-iqho-production.up.railway.app
#
# Checklist:
#   [ ] FEEDFOUNDRY_API_BASE_URL — server-only; upstream origin (no trailing slash)
#   [ ] FEEDFOUNDRY_INTERNAL_API_KEY — server-only; must match API; NEVER NEXT_PUBLIC_*
#   [ ] FEEDFOUNDRY_DEFAULT_ORG_ID=org_dev_demo (or your org) when browser sends no org header
#   [ ] NEXT_PUBLIC_APP_ENV=staging (optional; enables org override UI on System)
#   [ ] NEXT_PUBLIC_FEEDFOUNDRY_API_BASE_URL — public manifest fetches + System page public probes
#
# Server-only (never prefix with NEXT_PUBLIC_)
FEEDFOUNDRY_API_BASE_URL=https://api-v2-iqho-production.up.railway.app
FEEDFOUNDRY_INTERNAL_API_KEY=
FEEDFOUNDRY_DEFAULT_ORG_ID=org_dev_demo

# Public (safe for browser) — Archive page + System public health/ready probes
NEXT_PUBLIC_APP_ENV=staging
NEXT_PUBLIC_FEEDFOUNDRY_API_BASE_URL=https://api-v2-iqho-production.up.railway.app

# Dev: GET /v1/account/credits is mocked by default in `npm run dev` (no env required).
# In UI, present the balance as “processing allowance” (route name is legacy/internal).
# Opt in to real upstream: FEEDFOUNDRY_USE_LIVE_ACCOUNT_CREDITS=1

