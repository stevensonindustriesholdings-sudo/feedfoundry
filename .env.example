# -----------------------------------------------------------------------------
# FeedFoundry — environment template
# Matches `app.settings.Settings` and startup validation in `app.config.env_validation`.
# Staging/production (`APP_ENV=staging|production|prod`) require real DB, FF key, R2, Stripe.
#
# Docs: docs/runbook.md — customer-facing language uses “processing allowance” / processing minutes;
# Stripe/env keys containing CREDITS are deprecated naming; values are whole processing minutes. Never commit real secrets.
# -----------------------------------------------------------------------------

# App
APP_ENV=development
APP_NAME=feedfoundry
PUBLIC_API_BASE_URL=http://localhost:8000
API_VERSION=0.1.0

# CI / Railway image metadata (optional; surfaced on GET /version)
GIT_COMMIT=
BUILD_TIMESTAMP=

# Database
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/feedfoundry

# Internal API (Bearer for org-scoped routes)
FF_INTERNAL_API_KEY=replace_me
BASE44_WEBHOOK_SECRET=replace_me

# AI routing YAML (defaults under Docker to /app/ai-routing.yaml)
AI_ROUTING_CONFIG_PATH=

# Storage (R2 / S3-compatible)
# Choose ONE endpoint strategy:
#   Cloudflare R2  → set R2_ACCOUNT_ID; endpoint is constructed automatically.
#   Generic S3     → set R2_ENDPOINT_URL directly (e.g. Railway bucket endpoint).
# R2_ENDPOINT_URL takes precedence over R2_ACCOUNT_ID when both are set.
STORAGE_PROVIDER=r2
R2_ACCOUNT_ID=replace_me
R2_ENDPOINT_URL=
R2_REGION=auto
R2_ACCESS_KEY_ID=replace_me
R2_SECRET_ACCESS_KEY=replace_me
R2_BUCKET_SOURCE=feedfoundry-source-dev
R2_BUCKET_OUTPUTS=feedfoundry-outputs-dev
R2_PUBLIC_BASE_URL=
STORAGE_PRESIGN_PUT_EXPIRES_SECONDS=900
STORAGE_PRESIGN_GET_EXPIRES_SECONDS=900

# Stripe — webhooks + Checkout mapping (strict env requires non-placeholder keys)
# Annual hosted archive access (extends annual_access + grants included processing minutes on wallet).
# STRIPE_*_INCLUDED_CREDITS env names are legacy; values are whole processing minutes granted annually.
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_SECRET_KEY=sk_test_replace_me

# Annual plans: STRIPE_*_INCLUDED_CREDITS names are legacy; values = whole processing minutes / year.
STRIPE_ANNUAL_CORE_PRICE_ID=price_replace_me
STRIPE_ANNUAL_LITE_PRICE_ID=
STRIPE_ANNUAL_STUDIO_PRICE_ID=
STRIPE_ANNUAL_CORE_PLAN_CODE=creator_core
STRIPE_ANNUAL_LITE_PLAN_CODE=podcast_lite
STRIPE_ANNUAL_STUDIO_PLAN_CODE=creator_studio
STRIPE_ANNUAL_CORE_INCLUDED_CREDITS=300
STRIPE_ANNUAL_LITE_INCLUDED_CREDITS=100
STRIPE_ANNUAL_STUDIO_INCLUDED_CREDITS=1500
STRIPE_ANNUAL_ACCESS_PERIOD_DAYS=365

# Processing add-on packs (adds PURCHASE ledger units to wallet; Stripe var names unchanged — values are whole processing minutes)
STRIPE_CREDIT_PACK_100_PRICE_ID=price_replace_me
STRIPE_CREDIT_PACK_500_PRICE_ID=
STRIPE_CREDIT_PACK_1500_PRICE_ID=
STRIPE_CREDIT_PACK_100_CREDITS=100
STRIPE_CREDIT_PACK_500_CREDITS=500
STRIPE_CREDIT_PACK_1500_CREDITS=1500

# OpenAI / providers — optional until the real AI pipeline is wired
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=
OPENAI_CHEAP_TEXT_MODEL=
OPENAI_STANDARD_TEXT_MODEL=
ANTHROPIC_API_KEY=
ANTHROPIC_STANDARD_TEXT_MODEL=
GOOGLE_API_KEY=
GOOGLE_CHEAP_TEXT_MODEL=
MISTRAL_API_KEY=
MISTRAL_CHEAP_TEXT_MODEL=
DEEPSEEK_API_KEY=
DEEPSEEK_CHEAP_TEXT_MODEL=
GROQ_API_KEY=
GROQ_FAST_TEXT_MODEL=
LOCAL_TRANSCRIPTION_MODEL=
LOCAL_JSON_REPAIR_MODEL=

# AI budget controls (YAML + env; not required for API boot in dev)
DEV_MONTHLY_AI_BUDGET_USD=50
STAGING_MONTHLY_AI_BUDGET_USD=100
PRODUCTION_MONTHLY_AI_BUDGET_USD=1000
AI_SOFT_ALERT_PERCENT=60
AI_THROTTLE_PERCENT=80
AI_HARD_STOP_PERCENT=95

# -----------------------------------------------------------------------------
# Phase 7 — structured AI worker layer (apps/worker/ai/*) — placeholders only
# Docs: docs/ai-operating-brief.md, docs/phase7-railway-storage-provider-architecture.md
# Rule: mock-provider-first in CI/dev unless explicitly wiring real adapters.
# Worker service holds real OPENAI_* / provider keys — never expose to web/browser.
# -----------------------------------------------------------------------------
AI_PROVIDER=openai
AI_MODEL=gpt-4.1-mini
AI_FALLBACK_PROVIDER=
AI_FALLBACK_MODEL=
AI_MAX_JOB_COST=
AI_MAX_ORG_DAILY_COST=
AI_MAX_CONCURRENCY=2
AI_TIMEOUT_SECONDS=120
AI_RETRY_LIMIT=2
AI_ENABLE_MOCK_PROVIDER=true
AI_STRUCTURED_OUTPUTS_ENABLED=false
AI_VISUAL_ANALYSIS_ENABLED=false
AI_REPOSITORY_BEACON_ENABLED=false
AI_PRODUCT_GRID_ENABLED=false
AI_STORE_RUN_LOGS=true
AI_LOG_LEVEL=INFO

# Internal ops-only AI caps (engineering metrics; not customer processing minutes)
FF_INTERNAL_AI_MAX_UNITS_PER_JOB=
FF_INTERNAL_AI_MAX_CALLS_PER_JOB=
FF_INTERNAL_AI_ORG_WINDOW_MAX_UNITS=
FF_INTERNAL_AI_ORG_WINDOW_SECONDS=
STORAGE_PROVIDER=
STORAGE_BUCKET=
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_PUBLIC_BASE_URL=

# Worker (same DATABASE_URL / R2 / APP_ENV as API; no public HTTP port)
WORKER_POLL_INTERVAL_SECONDS=5
FF_WORKER_ID=
MAX_CONCURRENT_JOBS_PER_WORKER=2
FFMPEG_BINARY=ffmpeg
FFPROBE_BINARY=ffprobe
FF_SKIP_SOURCE_VERIFY=false

# Dev seed script — NEVER enable in production unless you intend to mutate prod data
ALLOW_DEV_SEED=false

# Smoke script (scripts/smoke_staging.py) — not read by the API
# SMOKE_BASE_URL=
# SMOKE_INTERNAL_KEY=
# SMOKE_ORG_ID=org_dev_demo
# SMOKE_MEDIA_ASSET_ID=
